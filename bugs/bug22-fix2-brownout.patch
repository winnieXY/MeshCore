From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MeshCore Security Audit <audit@meshcore.local>
Date: Tue, 22 Apr 2026 00:00:00 +0000
Subject: [PATCH 2/3] bug22: Add brownout detection (POFCON) for nRF52 platforms

The nRF52840 POWER peripheral has a power-failure comparator (POF) that
can warn when VDD drops below a configurable threshold. On solar-powered
devices like the SenseCAP Solar P1, battery voltage can sag during LoRa
TX bursts (up to 130mA). If voltage drops below the nRF52840 minimum
operating voltage during an NVMC flash erase (~85ms CPU stall), the
result is undefined — potentially a HardFault or flash corruption.

This patch adds brownout detection using the POF hardware:
- Enables the POFCON comparator at 2.4V threshold (nRF52840 min Vdd for
  flash write is 1.7V, but 2.4V gives margin for the voltage regulator)
- Polls for NRF_EVT_POWER_FAILURE_WARNING events in each loop()
- Sets a volatile flag that flash-writing code can check
- Logs a warning when brownout is detected

The POF comparator uses direct register access (no SoftDevice dependency)
so it works regardless of whether SD is enabled.

Note: This patch does NOT block flash writes during brownout. It only
provides detection and logging. Blocking writes requires changes to the
Adafruit LittleFS HAL which is outside the MeshCore tree.
---
 src/helpers/NRF52Board.cpp |  43 +++++++++++++++++++++++++++++++++++++
 src/helpers/NRF52Board.h   |  14 +++++++++++++
 2 files changed, 57 insertions(+)

diff --git a/src/helpers/NRF52Board.h b/src/helpers/NRF52Board.h
index 0000001..0000002 100644
--- a/src/helpers/NRF52Board.h
+++ b/src/helpers/NRF52Board.h
@@ -1,6 +1,7 @@
 #pragma once
 
 #include <Arduino.h>
+#include <nrf.h>
 #include <MeshCore.h>
 
 #if defined(NRF52_PLATFORM)
@@ -47,6 +48,19 @@
   NRF52Board(char *otaname) : ota_name(otaname) {}
   virtual void begin();
   virtual uint8_t getStartupReason() const override { return startup_reason; }
+
+  // Brownout detection — uses nRF52 POWER->POFCON hardware comparator.
+  // Call initBrownoutDetect() once in begin(), poll checkBrownout() in loop().
+  // When VDD drops below threshold, brownout_detected is set true.
+  void initBrownoutDetect(uint8_t threshold_vdd = 10,     // NRF_POWER_THRESHOLD_V24 = 2.4V
+                           uint8_t threshold_vddh = 0);   // 0 = don't set VDDH threshold
+  bool checkBrownout();
+  volatile bool brownout_detected = false;
+  uint32_t brownout_count = 0;
+
+  // Can be checked by flash-writing code to defer writes
+  bool isBrownout() const { return brownout_detected; }
+
   virtual float getMCUTemperature() override;
   virtual void reboot() override { NVIC_SystemReset(); }
   virtual bool getBootloaderVersion(char* version, size_t max_len) override;
diff --git a/src/helpers/NRF52Board.cpp b/src/helpers/NRF52Board.cpp
index 0000001..0000002 100644
--- a/src/helpers/NRF52Board.cpp
+++ b/src/helpers/NRF52Board.cpp
@@ -21,6 +21,49 @@ static void disconnect_callback(uint16_t conn_handle, uint8_t reason) {
 void NRF52Board::begin() {
   startup_reason = BD_STARTUP_NORMAL;
+
+  // Enable brownout detection with 2.4V threshold
+  initBrownoutDetect();
+}
+
+void NRF52Board::initBrownoutDetect(uint8_t threshold_vdd, uint8_t threshold_vddh) {
+  // The POFCON register is NOT managed by the SoftDevice —
+  // direct register access is safe in all configurations.
+  //
+  // POFCON register layout (nRF52840 Product Specification 6.1.2):
+  //   Bit 0:    POF enable (1 = enabled)
+  //   Bits 4-1: THRESHOLD (4=1.7V, 5=1.8V, ... 14=2.8V)
+  //
+  // We use 2.4V (value 10) as default: well above the 1.7V minimum for
+  // flash writes, gives the voltage regulator headroom during LoRa TX bursts.
+
+  NRF_POWER->POFCON = (1 << 0) |                           // Enable POF
+                       ((uint32_t)threshold_vdd << 1);      // VDD threshold
+
+  // Clear any stale POF event
+  NRF_POWER->EVENTS_POFWARN = 0;
+
+  // Enable interrupt for POF warning (fires NRF_EVT_POWER_FAILURE_WARNING
+  // if SoftDevice is enabled, or direct POWER_IRQ if not)
+  NRF_POWER->INTENSET = POWER_INTENSET_POFWARN_Msk;
+
+  brownout_detected = false;
+  brownout_count = 0;
+
+  MESH_DEBUG_PRINTLN("BROWNOUT: POF enabled, VDD threshold index=%u", threshold_vdd);
+}
+
+bool NRF52Board::checkBrownout() {
+  // Poll the hardware event register directly.
+  // This works whether SoftDevice is enabled or not.
+  if (NRF_POWER->EVENTS_POFWARN) {
+    NRF_POWER->EVENTS_POFWARN = 0;  // Clear for next detection
+
+    brownout_detected = true;
+    brownout_count++;
+
+    MESH_DEBUG_PRINTLN("BROWNOUT: Power failure warning #%lu! VDD below threshold",
+                       (unsigned long)brownout_count);
+    return true;
+  }
+
+  // Clear flag after voltage recovers (simple hysteresis)
+  brownout_detected = false;
+  return false;
 }
 
 #ifdef NRF52_POWER_MANAGEMENT
